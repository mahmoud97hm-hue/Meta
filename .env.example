# mt5-bridge environment profile (copy to .env and fill in)
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=3000
BRIDGE_API_KEY=

# MT5 terminal (auto-downloaded at build into the Wine prefix below)
MT5_TERMINAL_PATH=/root/.wine-mt5-terminal1/drive_c/MetaTrader5/terminal64.exe
MT5_WINE_PREFIX=/root/.wine-mt5-terminal1

# Broker credentials (match backend/config/accounts.json)
MT5_LOGIN=12345
MT5_PASSWORD=YOUR_PASSWORD_HERE
MT5_SERVER=FundingPips-Server

# State management
REDIS_URL=redis://127.0.0.1:6379/0

# Wine / display
WINEARCH=win64
WINEPREFIX=/root/.wine-mt5-terminal1
WINEDEBUG=-all
DISPLAY=:99
PYTHONHASHSEED=0
